root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,markdown}]
trim_trailing_whitespace = false

[*.{js,jsx,ts,tsx,mjs,cjs,json,yml,yaml,css,scss,html}]
indent_size = 2

[*.{java,kt}]
indent_size = 4
max_line_length = 120

[*.{dart}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{xml,svg}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2
