# Base URL of the Java Spring Cloud Gateway (the app proxies /api/** to it).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# Secret used to sign the short-lived session cookie that mirrors the JWT
# for server components (must differ from the backend JWT secret).
SESSION_COOKIE_SECRET=change-me-in-prod-min-32-bytes-0123456789abcdef

# Iter 161 — Google OAuth web client ID. Empty = "Mit Google anmelden"
# buttons stay hidden (no failed pop-ups in dev). In prod, set the
# OAuth-2.0 web-app client ID from Google Cloud Console; the *same*
# value must be configured on identity-service via GOOGLE_OAUTH_CLIENT_ID
# so that the ID-token audience check passes.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
