<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
        Shared logging configuration imported by every service.

        Profile "prod" emits JSON so Fluent Bit / Loki / ELK can ingest
        without extra parsing. Local dev stays plain-text for readability.

        MDC keys (populated by RequestContextFilter + Micrometer tracing):
        - traceId, spanId         (W3C trace-context)
        - correlationId           (X-Correlation-Id request/response header)
        - path, method            (request line)
        - userId                  (filled in by services that authenticate)

        Services override by creating their own src/main/resources/logback-spring.xml
        (which takes precedence over this one on the classpath).
    -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="bewerbi"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [${appName}] [trace=%X{traceId:-},corr=%X{correlationId:-},user=%X{userId:-}] [%X{method:-}%X{path:- }] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="prod">
        <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
                <pattern>{"ts":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","app":"${appName}","thread":"%thread","logger":"%logger","trace":"%X{traceId:-}","span":"%X{spanId:-}","corr":"%X{correlationId:-}","user":"%X{userId:-}","method":"%X{method:-}","path":"%X{path:-}","msg":"%replace(%msg){'\"','\\\"'}"}%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON"/>
        </root>
    </springProfile>

    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="tn.bewerbi" level="DEBUG"/>
    </springProfile>
</configuration>
